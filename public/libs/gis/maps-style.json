{
  "version": 8,
  "name": "Pakistan Offline Detailed",
  "sources": {
    "pakistan": {
      "type": "vector",
      "tiles": [
        "http://10.0.1.214/maps/data/pakistan/{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "glyphs": "/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2efe9"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "pakistan",
      "source-layer": "water",
      "paint": {
        "fill-color": "#88ccee"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "pakistan",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#66b5de",
        "line-width": 1
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "pakistan",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#dceccf"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "pakistan",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#e6ddb7",
        "fill-opacity": 0.45
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "pakistan",
      "source-layer": "park",
      "paint": {
        "fill-color": "#cfe8b4"
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "pakistan",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#666666",
        "line-width": 1
      }
    },
    {
      "id": "transportation-major",
      "type": "line",
      "source": "pakistan",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary", "secondary"]]],
      "paint": {
        "line-color": "#d39b2a",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.7,
          10, 2,
          14, 4
        ]
      }
    },
    {
      "id": "transportation-other",
      "type": "line",
      "source": "pakistan",
      "source-layer": "transportation",
      "paint": {
        "line-color": "#f0c977",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.3,
          10, 1,
          14, 2
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "pakistan",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-outline-color": "#c3bab3"
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "place",
      "minzoom": 3,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3, [
            "match",
            ["get", "class"],
            "city", 14,
            "town", 12,
            "village", 10,
            "hamlet", 9,
            10
          ],
          8, [
            "match",
            ["get", "class"],
            "city", 16,
            "town", 13,
            "village", 11,
            "hamlet", 10,
            11
          ],
          12, [
            "match",
            ["get", "class"],
            "city", 18,
            "town", 15,
            "village", 12,
            "hamlet", 11,
            12
          ]
        ],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "water-name-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "water_name",
      "minzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#2b6ea6",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "road-name-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "transportation_name",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"], ["get", "ref"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#7a5c1f",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "poi",
      "minzoom": 12,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "mountain-peak-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "mountain_peak",
      "minzoom": 8,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#6b6b6b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "aerodrome-labels",
      "type": "symbol",
      "source": "pakistan",
      "source-layer": "aerodrome_label",
      "minzoom": 9,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name_en"], ["get", "name"], ["get", "iata"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#5b4b8a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ]
}